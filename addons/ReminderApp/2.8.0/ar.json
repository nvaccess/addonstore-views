{"addonId": "ReminderApp", "displayName": "\u0627\u0644\u0645\u064f\u0630\u0643\u0651\u0650\u0631", "URL": "https://raw.githubusercontent.com/Adriano-Barbieri62/ReminderApp-Addon/main/ReminderApp-2.8.nvda-addon", "description": "\u062a\u0645 \u062a\u0635\u0645\u064a\u0645 \u0647\u0630\u0627 \u0627\u0644\u0645\u0644\u062d\u0642 \u0644\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u062a\u0630\u0643\u064a\u0631\u0627\u062a \u0648\u0627\u0644\u0645\u0648\u0627\u0639\u064a\u062f \u0648\u0627\u0644\u0630\u0643\u0631\u064a\u0627\u062a \u0627\u0644\u0633\u0646\u0648\u064a\u0629 \u0648\u0623\u0639\u064a\u0627\u062f \u0627\u0644\u0645\u064a\u0644\u0627\u062f \u0628\u0637\u0631\u064a\u0642\u0629 \u0623\u0635\u0644\u064a\u0629 \u0648\u0628\u062f\u064a\u0647\u064a\u0629.\n\u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 ReminderApp\u060c \u0644\u0646 \u062a\u062a\u0645\u0643\u0646 \u0641\u0642\u0637 \u0645\u0646 \u0625\u0646\u0634\u0627\u0621 \u062a\u0630\u0643\u064a\u0631\u0627\u062a\u0643 \u0648\u062a\u0646\u0638\u064a\u0645\u0647\u0627\u060c \u0628\u0644 \u0633\u064a\u0643\u0648\u0646 \u0644\u062f\u064a\u0643 \u0623\u064a\u0636\u064b\u0627 \u062f\u0641\u062a\u0631 \u0639\u0646\u0627\u0648\u064a\u0646 \u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0641\u064a \u0645\u062a\u0646\u0627\u0648\u0644 \u064a\u062f\u0643.\nNVDA+Shift+F1\u060c \u0625\u064a\u0642\u0627\u0641 \u0627\u0644\u062a\u0646\u0628\u064a\u0647 \u0627\u0644\u062c\u0627\u0631\u064a.\nNVDA+Shift+F2\u060c \u0641\u062a\u062d \u0648\u0627\u062c\u0647\u0629 ReminderApp \u0627\u0644\u0631\u0633\u0648\u0645\u064a\u0629\u060c \u0625\u0630\u0627 \u062a\u0645 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u064a\u0647 \u0645\u0631\u062a\u064a\u0646 \u064a\u062a\u0645 \u0625\u063a\u0644\u0627\u0642\u0647\u0627.\nNVDA+Shift+F3\u060c \u0639\u0631\u0636 \u0645\u0639\u0627\u064a\u0646\u0629 \u0644\u062a\u0630\u0643\u064a\u0631\u0627\u062a \u0627\u0644\u064a\u0648\u0645\u060c \u0648\u0625\u0630\u0627 \u062a\u0645 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u064a\u0647 \u0645\u0631\u062a\u064a\u0646 \u064a\u062a\u0645 \u0625\u063a\u0644\u0627\u0642\u0647\u0627.\n\u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u0627\u062a\u060c \u064a\u0645\u0643\u0646\u0643 \u0623\u064a\u0636\u064b\u0627 \u0627\u0644\u0636\u063a\u0637 \u0639\u0644\u0649 \u0632\u0631 \"\u0645\u0633\u0627\u0639\u062f\u0629 \u0627\u0644\u0645\u0644\u062d\u0642\" \u0641\u064a \u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0644\u062d\u0642\u0627\u062a.", "sha256": "b405d5af0ad75928eccd99b24267beea86dcbe843e4c4b002a7400604f0ca6ef", "addonVersionName": "2.8", "addonVersionNumber": {"major": 2, "minor": 8, "patch": 0}, "minNVDAVersion": {"major": 2020, "minor": 1, "patch": 0}, "lastTestedVersion": {"major": 2026, "minor": 1, "patch": 0}, "channel": "stable", "publisher": "Adriano Barbieri", "sourceURL": "https://github.com/Adriano-Barbieri62/ReminderApp-Addon", "license": "GPL v2", "homepage": "https://github.com/Adriano-Barbieri62/ReminderApp-Addon", "licenseURL": "https://www.gnu.org/licenses/gpl-2.0.html", "submissionTime": 1782582547000, "vtScanUrl": "https://www.virustotal.com/gui/file/b405d5af0ad75928eccd99b24267beea86dcbe843e4c4b002a7400604f0ca6ef", "scanResults": {"virusTotal": [{"_id": "b405d5af0ad75928eccd99b24267beea86dcbe843e4c4b002a7400604f0ca6ef", "_type": "file", "filecondis": {"dhash": "0000000006070400", "raw_md5": "25070908243751d7bb43c1b80181600b"}, "first_submission_date": 1782582553, "last_analysis_results": {}, "last_analysis_stats": {"confirmed-timeout": 0, "failure": 0, "harmless": 0, "malicious": 0, "suspicious": 0, "timeout": 0, "type-unsupported": 0, "undetected": 0}, "last_modification_date": 1782582554, "last_submission_date": 1782582553, "md5": "fcb9f257a88ac0948d1af2dd3f516cc4", "names": [], "reputation": 0, "sha1": "ccf3b93f7f1c696dd42cf632c5597909c3416d5f", "sha256": "b405d5af0ad75928eccd99b24267beea86dcbe843e4c4b002a7400604f0ca6ef", "size": 1