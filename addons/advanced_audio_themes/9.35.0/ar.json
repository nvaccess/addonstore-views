{"addonId": "advanced_audio_themes", "displayName": "\u0627\u0644\u062b\u064a\u0645\u0627\u062a \u0627\u0644\u0635\u0648\u062a\u064a\u0629 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629", "URL": "https://github.com/HassanAlBarshoumy/advanced_audio_themes/releases/download/v9.35/advanced_audio_themes-9.35.nvda-addon", "description": "\u0623\u062d\u062f\u062b \u062b\u0648\u0631\u0629\u064b \u0641\u064a \u062a\u062c\u0631\u0628\u062a\u0643 \u0645\u0639 \u0642\u0627\u0631\u0626 \u0627\u0644\u0634\u0627\u0634\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \"\u0627\u0644\u062b\u064a\u0645\u0627\u062a \u0627\u0644\u0635\u0648\u062a\u064a\u0629 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629\"\u060c \u0627\u0644\u0645\u0644\u0627\u0630 \u0627\u0644\u0633\u0645\u0639\u064a \u0627\u0644\u0623\u0642\u0648\u0649 \u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a NVDA.\n\n\u0627\u0646\u063a\u0645\u0633 \u0641\u064a \u0639\u0627\u0644\u0645\u064d \u0635\u0648\u062a\u064a \u062f\u064a\u0646\u0627\u0645\u064a\u0643\u064a \u062b\u0644\u0627\u062b\u064a \u0627\u0644\u0623\u0628\u0639\u0627\u062f\u061b \u062d\u064a\u062b \u062a\u0646\u0628\u0636 \u0643\u0644 \u062d\u0631\u0643\u0629 \u0639\u0644\u0649 \u0627\u0644\u0634\u0627\u0634\u0629 \u0628\u0627\u0644\u062d\u064a\u0627\u0629\u2014\u0645\u0646 \u0627\u0644\u062a\u0646\u0642\u0644 \u0628\u064a\u0646 \u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0623\u0634\u0631\u0637\u0629 \u0627\u0644\u062a\u0642\u062f\u0645\u060c \u0648\u0635\u0648\u0644\u0627\u064b \u0625\u0644\u0649 \u0623\u0635\u0648\u0627\u062a \u0627\u0644\u0643\u062a\u0627\u0628\u0629\u2014\u0639\u0628\u0631 \u0645\u0624\u062b\u0631\u0627\u062a \u0635\u0648\u062a\u064a\u0629 \u0645\u0643\u0627\u0646\u064a\u0629 \u063a\u0646\u064a\u0629 \u0648\u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u062a\u062e\u0635\u064a\u0635 \u0627\u0644\u0645\u0637\u0644\u0642. \u0648\u0645\u0639 \"\u0627\u0633\u062a\u0648\u062f\u064a\u0648 \u0627\u0644\u062b\u064a\u0645\u0627\u062a\" \u0627\u0644\u0645\u062f\u0645\u062c\u060c \u064a\u0645\u0643\u0646\u0643 \u0628\u0643\u0644 \u0633\u0644\u0627\u0633\u0629 \u0635\u064a\u0627\u063a\u0629 \u062b\u064a\u0645\u0627\u062a\u0643 \u0627\u0644\u062e\u0627\u0635\u0629\u060c \u0623\u0648 \u062a\u0635\u0641\u062d \u0648\u062a\u062d\u0645\u064a\u0644 \u0645\u0643\u062a\u0628\u0629 \u0633\u062d\u0627\u0628\u064a\u0629 \u0645\u062a\u062c\u062f\u062f\u0629 \u0645\u0646 \u0625\u0628\u062f\u0627\u0639\u0627\u062a \u0627\u0644\u0645\u062c\u062a\u0645\u0639.\n\n\u0627\u0631\u062a\u0642\u0650 \u0628\u0625\u0646\u062a\u0627\u062c\u064a\u062a\u0643 \u0639\u0628\u0631 \u0645\u0632\u0627\u064a\u0627 \u0627\u0633\u062a\u062b\u0646\u0627\u0626\u064a\u0629:\n- \u0645\u0639\u0627\u0644\u062c\u0629 \u0635\u0648\u062a\u064a\u0629 \u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 (DSP): \u0639\u0632\u0632 \u0646\u0642\u0627\u0621 \u0627\u0644\u0635\u0648\u062a \u0645\u0639 \u0645\u0636\u062e\u0645\u0627\u062a \u0627\u0644\u0635\u0648\u062a (Bass Boost)\u060c \u0639\u0648\u0627\u0632\u0644 \u0627\u0644\u0636\u062c\u064a\u062c (Noise Gate)\u060c \u0648\u062e\u0641\u0636 \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0630\u0643\u064a.\n- \u0623\u0635\u0648\u0627\u062a \u062d\u0627\u0644\u0629 \u0627\u0644\u0646\u0638\u0627\u0645: \u0643\u0646 \u0639\u0644\u0649 \u062f\u0631\u0627\u064a\u0629 \u062a\u0627\u0645\u0629 \u0628\u0646\u0628\u0636 \u062d\u0627\u0633\u0648\u0628\u0643 \u0639\u0628\u0631 \u0625\u0634\u0639\u0627\u0631\u0627\u062a \u0635\u0648\u062a\u064a\u0629 \u0641\u0648\u0631\u064a\u0629 \u0644\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u0628\u0637\u0627\u0631\u064a\u0629\u060c \u0648\u0627\u0644\u0634\u0628\u0643\u0629\u060c \u0648\u0645\u0646\u0627\u0641\u0630 \u0627\u0644\u0640 USB\u060c \u0648\u0627\u0644\u0637\u0627\u0642\u0629.\n- \u0645\u0644\u0641\u0627\u062a \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0630\u0643\u064a\u0629: \u0639\u0634 \u062a\u062c\u0631\u0628\u0629 \u062a\u062a\u0643\u064a\u0641 \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b\u060c \u062d\u064a\u062b \u062a\u062a\u063a\u064a\u0631 \u0627\u0644\u062b\u064a\u0645\u0627\u062a \u0648\u0623\u0635\u0648\u0627\u062a \u0627\u0644\u0643\u062a\u0627\u0628\u0629 \u0628\u0633\u0644\u0627\u0633\u0629 \u062d\u0633\u0628 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0645\u0641\u062a\u0648\u062d.\n- \u0627\u0644\u0633\u0648\u0646\u0627\u0631 \u0648\u0627\u0644\u0645\u0646\u0627\u0631\u0627\u062a \u0627\u0644\u0635\u0648\u062a\u064a\u0629 (3D): \u0627\u0631\u0633\u0645 \u062e\u0631\u064a\u0637\u0629 \u0630\u0647\u0646\u064a\u0629 \u0644\u0634\u0627\u0634\u062a\u0643 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0646\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u0643\u0627\u0646\u064a\u0629 \u0648\u0645\u0648\u062c\u0627\u062a \u0627\u0644\u0633\u0648\u0646\u0627\u0631 \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0643\u0634\u0641 \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0628\u062f\u0642\u0629 \u0627\u0644\u0631\u0627\u062f\u0627\u0631.\n- \u062a\u0646\u0642\u0644 \u0641\u0627\u0626\u0642 \u0627\u0644\u0633\u0631\u0639\u0629: \u062a\u062d\u0631\u0631 \u0645\u0646 \u0642\u064a\u0648\u062f \u0644\u0648\u062d\u0629 \u0627\u0644\u0645\u0641\u0627\u062a\u064a\u062d \u0627\u0644\u0645\u0639\u0642\u062f\u0629 \u0639\u0628\u0631 \"\u0637\u0628\u0642\u0629 \u0627\u0644\u062a\u0646\u0642\u0644\" \u0627\u0644\u062d\u0631\u0629\u060c \u0648\u0627\u0644\u0627\u0646\u062f\u0645\u0627\u062c \u0627\u0644\u0639\u0645\u064a\u0642 \u0645\u0639 \u0645\u062d\u0631\u0643\u0627\u062a BrowserNav \u0648 SentenceNav.\n- \u0627\u0644\u0642\u0648\u0627\u0639\u062f \u0627\u0644\u0635\u0648\u062a\u064a\u0629 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629: \u0627\u0645\u062a\u0644\u0643 \u0632\u0645\u0627\u0645 \u0627\u0644\u062a\u062d\u0643\u0645 \u0627\u0644\u0643\u0627\u0645\u0644 \u0641\u064a \u0646\u0637\u0642 \u0627\u0644\u0643\u0644\u0645\u0627\u062a \u0648\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0642\u0648\u0627\u0639\u062f \u0646\u0637\u0642 \u0645\u062e\u0635\u0635\u0629 \u0648\u0625\u0634\u0627\u0631\u0627\u062a \u0635\u0648\u062a\u064a\u0629 \u062f\u0642\u064a\u0642\u0629.\n\n\u062a\u062c\u0627\u0648\u0632 \u062d\u062f\u0648\u062f \u0627\u0644\u0642\u0631\u0627\u0621\u0629 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629\u060c \u0648\u0623\u0637\u0644\u0642 \u0627\u0644\u0639\u0646\u0627\u0646 \u0644\u0628\u064f\u0639\u062f\u064d \u0633\u0645\u0639\u064a \u0645\u0630\u0647\u0644 \u064a\u0631\u0627\u0641\u0642\u0643 \u0641\u064a \u0643\u0644 \u0645\u0647\u0627\u0645\u0643!", "sha256": "3f421ec9d14930365b2c9b2c692c596ff5f622936265048d85cb6db799f224e8", "addonVersionName": "9.35", "addonVersionNumber": {"major": 9, "minor": 35, "patch": 0}, "minNVDAVersion": {"major": 2024, "minor": 1, "patch": 0}, "lastTestedVersion": {"major": 2026, "minor": 2, "patch": 0}, "channel": "beta", "publisher": "Hassan AlBarshoumy", "sourceURL": "https://github.com/HassanAlBarshoumy/advanced_audio_themes", "license": "GPL v2", "homepage": "https://github.com/HassanAlBarshoumy/advanced_audio_themes", "licenseURL": "https://www.gnu.org/licenses/gpl-2.0.html", "submissionTime": 1783848195000, "vtScanUrl": "https://www.virustotal.com/gui/file/3f421ec9d14930365b2c9b2c692c596ff5f622936265048d85cb6db799f224e8", "scanResults": {"virusTotal": [{"_id": "3f421ec9d14930365b2c9b2c692c596ff5f622936265048d85cb6db799f224e8", "_type": "file", "filecondis": {"dhash": "000000000f0e0600", "raw_md5": "43687990a103138597152c122a40b708"}, "first_submission_date": 1783848201, "last_analysis_results": {}, "last_analysis_stats": {"confirmed-timeout": 0, "failure": 0, "harmless": 0, "malicious": 0, "suspicious": 0, "timeout": 0, "type-unsupported": 0, "undetected": 0}, "last_modification_date": 1783848210, "last_submission_date": 1783848201, "md5": "633f8ce48d2c0bdd6fe132fda501aee0", "na